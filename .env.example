# Local API settings; copy to .env.local for development and never commit secrets.
API_PORT=4317
NODE_ENV=development

# Optional PostgreSQL integration. Leave unset to run the app without a database.
DATABASE_URL=postgres://gnosis:gnosis@localhost:5432/gnosis_ledger_inventory

# Optional isolated integration-test database/schema.
TEST_DATABASE_URL=postgres://gnosis:gnosis@localhost:5432/gnosis_ledger_inventory_test

# Local internal auth defaults for seed data. Override in local App Settings as needed.
DEFAULT_ADMIN_EMAIL=admin@nueprint.local
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
AUTH_TOKEN_SECRET=replace-with-local-development-secret
